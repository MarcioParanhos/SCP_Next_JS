datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  password      String? // se usar Credentials (hash com bcrypt)
  image         String?
  accounts      Account[]
  sessions      Session[]
  // Relação inversa: homologações realizadas por este usuário
  homologations Homologation[]
  // Relação inversa: carências criadas por este usuário
  carencias     Carencia[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Nte {
  id             Int            @id @default(autoincrement())
  name           String
  municipalities Municipality[]

  @@map("nte")
}

model Municipality {
  id      Int          @id @default(autoincrement())
  name    String
  nte_id  Int
  nte     Nte          @relation(fields: [nte_id], references: [id])
  schools SchoolUnit[]

  @@map("municipalities")
}

model SchoolUnit {
  id              Int            @id @default(autoincrement())
  name            String
  sec_cod         String         @map("sec_cod")
  uo_code         String         @default("UNKNOWN") @map("uo_code")
  status          String         @default("1")
  typology_id     Int?
  typology        Typology?      @relation(fields: [typology_id], references: [id])
  municipality_id Int
  municipality    Municipality   @relation(fields: [municipality_id], references: [id])
  // Relação inversa para registrar as homologações vinculadas a esta unidade
  homologations   Homologation[]
  // Relação inversa: carências registradas nesta unidade
  carencias       Carencia[]

  @@map("school_units")
}

model Discipline {
  id        Int        @id @default(autoincrement())
  name      String
  // Relação inversa: carências que usam esta disciplina
  carencias Carencia[]

  @@map("disciplines")
}

model Eixo {
  id      Int      @id @default(autoincrement())
  name    String
  courses Course[]

  @@map("eixos")
}

model Course {
  id        Int        @id @default(autoincrement())
  name      String
  eixo_id   Int
  eixo      Eixo       @relation(fields: [eixo_id], references: [id])
  // Relação inversa: carências vinculadas a este curso
  carencias Carencia[]

  @@map("courses")
}

model Typology {
  id    Int          @id @default(autoincrement())
  name  String
  units SchoolUnit[]

  @@map("typologies")
}

// Modelo: Employee (Servidor)
// Armazena cada servidor público / professor registrado no sistema.
// Os campos correspondem às colunas exibidas na tela "Lista de Servidores".
model Employee {
  id            Int      @id @default(autoincrement())
  name          String // Nome completo do servidor
  cpf           String // Número de CPF
  enrollment    String   @default("PENDING") // Número de matrícula funcional (PENDING até atribuído)
  bond_type     String // Tipo de vínculo (ex.: REDA, EFETIVO, DESIGNADO)
  work_schedule String // Jornada de trabalho (ex.: 20H, 40H, DE)
  createdAt     DateTime   @default(now()) // Timestamp de criação do registro
  updatedAt     DateTime   @updatedAt // Timestamp da última atualização (gerenciado pelo Prisma)
  // Relação inversa: carências geradas por este servidor
  carencias     Carencia[]

  @@map("employees") // Nome da tabela no banco
}

// Modelo para registrar ações de homologação / deshomologação
// Cada registro representa uma ação executada sobre uma unidade escolar
model Homologation {
  id              Int        @id @default(autoincrement())
  action          String // ex.: "HOMOLOGATED" | "UNHOMOLOGATED"
  reason          String? // motivo/observação fornecida pelo usuário
  // Chave estrangeira para o usuário que executou a ação
  // - Substituiu a coluna `performed_by` (antes armazenava email como texto livre)
  // - ON DELETE SET NULL: se o usuário for removido, o histórico permanece
  performed_by_id String?
  performedBy     User?      @relation(fields: [performed_by_id], references: [id], onDelete: SetNull)
  school_unit_id  Int
  schoolUnit      SchoolUnit @relation(fields: [school_unit_id], references: [id])
  createdAt       DateTime   @default(now())

  @@index([school_unit_id])
  @@map("homologations")
}

// Tipo de carência: define se o motivo pertence a carência real ou temporária
enum CarenciaType {
  REAL
  TEMPORARY
}

// Tabela para armazenar os motivos de carência. Alguns motivos são específicos
// para `REAL` e outros para `TEMPORARY`. Usamos `type` para diferenciar.
model Motive {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  description String
  type        CarenciaType
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  // Relação inversa: carências que usam este motivo
  carencias   Carencia[]

  @@map("carencia_motives")
}

// Tabela para áreas pedagógicas usadas nas carências
model Area {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  // Relação inversa: carências vinculadas a esta área pedagógica
  carencias Carencia[]

  @@map("carencia_areas")
}

// Modelo para armazenar a carência (real ou temporária).
model Carencia {
  id             Int           @id @default(autoincrement())
  type           CarenciaType  // REAL ou TEMPORARY
  school_unit_id Int
  schoolUnit     SchoolUnit    @relation(fields: [school_unit_id], references: [id])
  // servidor que gerou a carência (employee)
  server_id      Int?
  server         Employee?     @relation(fields: [server_id], references: [id])
  discipline_id  Int?          // disciplina principal, opcional
  discipline     Discipline?   @relation(fields: [discipline_id], references: [id])
  area_id        Int?
  area           Area?         @relation(fields: [area_id], references: [id])
  motive_id      Int?
  motive         Motive?       @relation(fields: [motive_id], references: [id])
  startDate      DateTime?
  course_id      Int?
  course         Course?       @relation(fields: [course_id], references: [id])
  // Quantitativos por turno armazenados também na tabela principal para
  // consultas rápidas sem necessidade de join nas linhas.
  morning        Int           @default(0)
  afternoon      Int           @default(0)
  night          Int           @default(0)
  total          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Usuário que criou a carência (opcional) — relation para `User`
  created_by_id  String?
  createdBy      User?         @relation(fields: [created_by_id], references: [id], onDelete: SetNull)

  // Linhas detalhadas (disciplinas/quantitativos) relacionadas
  rows CarenciaRow[]

  @@index([created_by_id])

  @@map("carencias")
}

// Linhas que detalham disciplinas / quantidades por turno para uma carência
model CarenciaRow {
  id           Int       @id @default(autoincrement())
  carencia_id  Int
  carencia     Carencia  @relation(fields: [carencia_id], references: [id])
  discipline   String?
  area         String?
  reason       String?
  morning      Int       @default(0)
  afternoon    Int       @default(0)
  night        Int       @default(0)
  createdAt    DateTime  @default(now())

  @@map("carencia_rows")
}
