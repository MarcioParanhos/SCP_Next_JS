datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String? // se usar Credentials (hash com bcrypt)
  image         String?
  accounts      Account[]
  sessions      Session[]
  // Relação inversa: homologações executadas por este usuário
  homologations Homologation[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Nte {
  id             Int            @id @default(autoincrement())
  name           String
  municipalities Municipality[]

  @@map("nte")
}

model Municipality {
  id      Int          @id @default(autoincrement())
  name    String
  nte_id  Int
  nte     Nte          @relation(fields: [nte_id], references: [id])
  schools SchoolUnit[]

  @@map("municipalities")
}

model SchoolUnit {
  id              Int            @id @default(autoincrement())
  name            String
  sec_cod         String         @map("sec_cod")
  uo_code         String         @default("UNKNOWN") @map("uo_code")
  status          String         @default("1")
  typology_id     Int?
  typology        Typology?      @relation(fields: [typology_id], references: [id])
  municipality_id Int
  municipality    Municipality   @relation(fields: [municipality_id], references: [id])
  // Relação inversa para registrar as homologações relacionadas a esta unidade
  homologations   Homologation[]

  @@map("school_units")
}

model Discipline {
  id   Int    @id @default(autoincrement())
  name String

  @@map("disciplines")
}

model Typology {
  id    Int          @id @default(autoincrement())
  name  String
  units SchoolUnit[]

  @@map("typologies")
}

// Model: Employee (Servidor)
// Stores every public servant / teacher registered in the system.
// Fields map 1-to-1 with the columns shown on the "Lista de Servidores" screen.
model Employee {
  id            Int      @id @default(autoincrement())
  name          String                               // Full name of the employee
  cpf           String                               // Brazilian CPF tax number
  enrollment    String   @default("PENDING")         // Functional enrollment number (PENDING until assigned)
  bond_type     String                               // Employment bond type (e.g. REDA, EFETIVO, DESIGNADO)
  work_schedule String                               // Work schedule / shift (e.g. 20H, 40H, DE)
  createdAt     DateTime @default(now())             // Record creation timestamp
  updatedAt     DateTime @updatedAt                  // Last update timestamp (managed by Prisma)

  @@map("employees") // Database table name
}

// Modelo para registrar ações de homologação/deshomologação
// Cada registro representa uma ação executada sobre uma unidade escolar
model Homologation {
  id               Int        @id @default(autoincrement())
  action           String     // e.g. "HOMOLOGATED" | "UNHOMOLOGATED"
  reason           String?    // motivo/observação fornecida pelo usuário
  // Chave estrangeira para o usuário que executou a ação
  // - Substituiu a coluna `performed_by` (que armazenava email como texto livre)
  // - ON DELETE SET NULL: se o usuário for removido, o registro histórico permanece
  performed_by_id  String?
  performedBy      User?      @relation(fields: [performed_by_id], references: [id], onDelete: SetNull)
  school_unit_id   Int
  schoolUnit       SchoolUnit @relation(fields: [school_unit_id], references: [id])
  createdAt        DateTime   @default(now())

  @@index([school_unit_id])
  @@map("homologations")
}
